{
  "name": "flop",
  "version": "1.0.0",
  "author": "User",
  "description": "FLAC Player",
  "main": "src/main.js",
  "scripts": {
    "electron": "electron .",
    "start": "electron .",
    "build": "cross-env CSC_SKIP_SIGNING=true electron-builder --win --x64",
    "build:portable": "cross-env CSC_SKIP_SIGNING=true electron-builder --win portable --x64"
  },
  "dependencies": {
    "metaflac-js": "^1.0.5",
    "music-metadata": "^7.14.0",
    "node-id3": "^0.2.9"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-reload": "^1.5.0"
  },
  "build": {
    "appId": "com.flop.app",
    "productName": "flop",
    "win": {
      "target": [
        "portable"
      ],
      "icon": "src/assets/icon.png"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}",
      "requestExecutionLevel": "user"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "styles/**/*",
      "package.json"
    ]
  }
}
